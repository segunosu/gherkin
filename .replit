modules = ["python-3.11"]

run = "streamlit run app.py --server.port 8080 --server.address 0.0.0.0 --server.headless true --browser.gatherUsageStats false"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "streamlit run app.py --server.port 8080 --server.address 0.0.0.0 --server.headless true --browser.gatherUsageStats false"]
deploymentTarget = "autoscale"

[[ports]]
localPort = 8080
externalPort = 80

[agent]
expertMode = true

[userenv]

[userenv.shared]
